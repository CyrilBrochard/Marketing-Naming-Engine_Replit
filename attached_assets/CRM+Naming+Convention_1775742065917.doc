p2]{color:#0747a6} html[data-color-mode=3Ddark] [data-colorid=3Dpjshsb9rp2]=
{color:#5999f8}[data-colorid=3Djo7fp5z7ie]{color:#0747a6} html[data-color-m=
ode=3Ddark] [data-colorid=3Djo7fp5z7ie]{color:#5999f8}[data-colorid=3Durlio=
kw7xq]{color:#0747a6} html[data-color-mode=3Ddark] [data-colorid=3Durliokw7=
